    "knownIssues": {
      "accountNumbers": "AccountNumber field must be explicitly preserved \u2014 was being dropped during transformation. FIXED.",
      "ccBalanceSign": "Credit Card account balances may be inverted (negative in 2023, should be positive in 2021). FIXED.",
      "ccColumns": "Credit card columns were reversed in reports. FIXED in earlier session.",
      "trialBalance": "Trial balance mismatch \u2014 ensure all journal entries import with correct debit/credit amounts.",
      "emptyNames": "Some entities export with empty Name fields \u2014 auto-generated placeholders applied. FIXED."
    }
  },
