  "formatRules": {
    "preserveDateFormat": true,
    "dateFormatStandard": "QBXML",
    "preserveCurrencyFormat": true,
    "currencyDecimalPlaces": 2,
    "preservePhoneFormat": true,
    "preservePostalCodeFormat": true,
    "truncationBehavior": "PreserveFormat",
    "preserveMemoFormatting": true,
    "preserveEncoding": true,
    "stripTimezoneFromDates": true,
    "dateFieldPatterns": [
      "Date",
      "DueDate",
      "TxnDate",
      "ShipDate",
      "ServiceDate",
      "HiredDate",
      "ReleasedDate",
      "BirthDate",
      "OpenBalanceDate",
      "ExpectedDate",
      "TimeCreated",
      "TimeModified"
    ],
    "currencyFieldPatterns": [
      "Amount",
      "Balance",
      "Price",
      "Rate",
      "Cost",
      "Total",
      "CreditLimit",
      "OpenBalance",
      "Subtotal"
    ]
  },
  "transformFunctions": {
    "MapJobStatus": {
      "description": "Maps QB 2023 job status values to QB 2021 equivalents",
      "mappings": {
        "Awarded": "Awarded",
        "Closed": "Closed",
        "InProgress": "InProgress",
        "None": "None",
        "NotAwarded": "NotAwarded",
        "Pending": "Pending",
        "InNegotiation": "Pending",
        "OnHold": "Pending"
      },
      "defaultValue": "None"
    },
    "TruncateString": {
      "description": "Truncates string to maxLength if exceeded",
      "parameters": {
        "maxLength": "Defined per field mapping"
      }
    },
    "MapPaymentMethod": {
      "description": "Maps newer payment method types to QB 2021 equivalents",
      "mappings": {
        "Venmo": "Other",
        "Zelle": "Other",
        "CashApp": "Other",
        "ApplePay": "Other",
        "GooglePay": "Other",
        "Cash": "Cash",
        "Check": "Check",
        "CreditCard": "CreditCard",
        "DebitCard": "DebitCard",
        "ECheck": "ECheck",
        "AmEx": "AmEx",
        "Discover": "Discover",
        "MasterCard": "MasterCard",
        "Visa": "Visa"
      },
      "defaultValue": "Other"
    }
  }
}