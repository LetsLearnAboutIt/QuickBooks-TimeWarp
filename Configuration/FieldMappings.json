{
  "_documentation": {
    "description": "Field mapping configuration for QuickBooks 2023 to 2021 migration",
    "version": "1.0.0",
    "instructions": [
      "Each entity type has a 'fieldMappings' array defining how QB 2023 fields map to QB 2021 fields.",
      "Set 'action' to: 'map' (direct or renamed mapping), 'transform' (apply transformation), 'default' (use default value), 'skip' (ignore field).",
      "The 'transformFunction' field references built-in transformation functions (see Helpers/TransformFunctions.cs).",
      "Add or modify mappings as needed for your specific data."
    ],
    "commonDifferences": {
      "QB2023_vs_QB2021": [
        "QB 2023 added enhanced inventory tracking fields not present in 2021",
        "QB 2023 has expanded address fields (Address6 line) collapsed back to 5 lines in 2021",
        "Custom field naming conventions may differ",
        "Some newer payment method types in 2023 need mapping to generic equivalents",
        "QB 2023 added new job status values not recognized by 2021",
        "Date format handling is consistent but timezone-aware fields in 2023 need stripping",
        "QB 2023 supports longer field lengths for some text fields (Name: 209 vs 41 chars in older)"
      ]
    },
    "transformationRules": {
      "ReactivateInactiveEntities": "All inactive entities (Customers, Vendors, Items, Accounts, Employees) from QB 2023 are set to IsActive=true during transformation. Controlled by TransformationRules.ReactivateInactiveEntities in appsettings.json.",
      "PreserveClassTracking": "Class assignments on transactions (Invoices, Bills, Journal Entries, Sales Receipts, Purchase Orders) are preserved. ClassRef.FullName is mapped at both header and line item levels. Missing classes are auto-created in QB 2021. Controlled by TransformationRules.PreserveClassTracking.",
      "MatchAccountingModel": "The accounting method (Cash basis vs Accrual basis) and ReportBasis from QB 2023 are queried and applied to QB 2021 via QBXML PreferencesQuery/PreferencesMod. Controlled by TransformationRules.MatchAccountingModel."
    },
    "formatRules": {
      "description": "Controls how field-specific formats are preserved during transformation.",
      "preserveDateFormat": "When true, date fields maintain QBXML standard format (yyyy-MM-dd). Timestamps use yyyy-MM-ddTHH:mm:ss. Timezone info is stripped for QB 2021 compatibility.",
      "preserveCurrencyFormat": "When true, currency/amount fields preserve decimal precision (default 2 places). Currency symbols are stripped for QBXML compatibility.",
      "preservePhoneFormat": "When true, phone numbers maintain their formatting (dashes, parentheses) within QB 2021's 21-char limit.",
      "preservePostalCodeFormat": "When true, postal codes preserve leading zeros and hyphenated ZIP+4 format.",
      "truncationBehavior": "PreserveFormat = format-aware truncation (won't break dates, truncates memos at word boundaries). Standard = simple character truncation.",
      "preserveMemoFormatting": "When true, line breaks and special characters in Memo/Notes fields are preserved.",
      "preserveEncoding": "When true, UTF-8 encoding is maintained for special characters."
    }
  },
  "globalSettings": {
    "dateFormat": "yyyy-MM-dd",
    "truncateLongStrings": true,
    "unmappedFieldAction": "skip",
    "logUnmappedFields": true,
    "targetSDKVersion": "15.0",
    "targetQBVersion": "2021",
    "enforceQB2021FieldLimits": true
  },
  "qb2021Compatibility": {
    "_description": "Documents fields NOT supported in QB 2021 (SDK 15.0). These are automatically stripped by DataTransformer and DataImporter.",
    "sdk16OnlyFields": [
      "ExternalGUID",
      "TaxRegistrationNumber",
      "CurrencyRef",
      "PreferredDeliveryMethod",
      "EmployeeType",
      "EmployeePayrollInfo",
      "BillingRateRef",
      "UnitOfMeasureSetRef",
      "ForceUOMChange",
      "ExchangeRate",
      "LinkToTxnID",
      "SubscriptionPaymentStatus",
      "DeliveryInfo",
      "TaxLineRef",
      "DetailAccountType",
      "TaxLineID",
      "QuantityOnSalesOrder",
      "QuantityOnPurchaseOrder",
      "Sublevel",
      "SpecialItemType"
    ],
    "_note_detailAccountType": "DetailAccountType is NOT in SDK 15.0 \u2014 only AccountType is valid for QB 2021. Use AccountType for all account imports.",
    "sdk16OnlyEntityTypes": [
      "TransferInventory"
    ],
    "fieldLengthDifferences": {
