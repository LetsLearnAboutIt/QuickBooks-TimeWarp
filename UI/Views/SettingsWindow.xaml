<Window x:Class="QB_TimeWarp.UI.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — Company File TimeWarp"
        Width="680" Height="680"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#E8ECF1"
        ResizeMode="CanResizeWithGrip"
        Icon="/UI/Assets/osa-icon.png">

    <Border Background="#151B28" BorderBrush="#1A2332" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />    <!-- Title Bar -->
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="*" />     <!-- Content -->
            <RowDefinition Height="Auto" />  <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#0D1117"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Image Source="/UI/Assets/osa-icon.png" Width="16" Height="16"
                           RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0" />
                    <TextBlock Text="Settings" FontSize="12"
                               Foreground="#6B7A90" VerticalAlignment="Center" />
                </StackPanel>
                <Button Content="&#xE8BB;" Click="Cancel_Click"
                        Style="{StaticResource WindowCloseButton}"
                        HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Header bar -->
        <Border Grid.Row="1" Background="#0D1117" Padding="24,16">
            <StackPanel>
                <TextBlock Text="⚙  Settings" FontSize="20" FontWeight="SemiBold" Foreground="#E8ECF1" />
                <TextBlock Text="Configure connections, import options, and paths"
                           FontSize="12" Foreground="#6B7A90" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Scrollable settings content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,16"
                      Style="{StaticResource ThinScrollViewer}">
            <StackPanel Margin="24,16,24,8">

                <!-- ── Connection Card ───────────────────────────────── -->
                <Border Background="#1C2333" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                        BorderBrush="#2A3448" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="QB Connection" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#E8ECF1" Margin="0,0,0,16" />

                        <!-- QB 2023 Source -->
                        <TextBlock Text="SOURCE — QB 2023" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#00B4D8" Margin="0,0,0,8" />

                        <TextBlock Text="Company File Path" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="QB2023Path" Style="{StaticResource ModernTextBox}" />
                            <Button Grid.Column="1" Content="Browse" Click="BrowseQB2023_Click"
                                    Style="{StaticResource ToolbarButtonSecondary}" Margin="8,0,0,0" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SDK Version" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="QB2023SDKVersion" Text="16.0" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Timeout (sec)" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="QB2023Timeout" Text="300" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                        </Grid>

                        <Separator Background="#2A3448" Margin="0,8,0,12" />

                        <!-- QB 2021 Target -->
                        <TextBlock Text="TARGET — QB 2021" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#4ADE80" Margin="0,0,0,8" />

                        <TextBlock Text="Company File Path" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="QB2021Path" Style="{StaticResource ModernTextBox}" />
                            <Button Grid.Column="1" Content="Browse" Click="BrowseQB2021_Click"
                                    Style="{StaticResource ToolbarButtonSecondary}" Margin="8,0,0,0" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SDK Version" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="QB2021SDKVersion" Text="15.0" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max Retries" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="MaxRetries" Text="3" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Export / Import Card ───────────────────────────── -->
                <Border Background="#1C2333" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                        BorderBrush="#2A3448" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Export &amp; Import Options" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#E8ECF1" Margin="0,0,0,16" />

                        <TextBlock Text="DATE RANGE FILTER" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#00B4D8" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="From Date" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="DateFrom" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="To Date" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="DateTo" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                        </Grid>

                        <Separator Background="#2A3448" Margin="0,4,0,12" />

                        <TextBlock Text="IMPORT OPTIONS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#4ADE80" Margin="0,0,0,8" />
                        <CheckBox x:Name="SkipOnError" Content="Skip on Error (continue importing)"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                        <CheckBox x:Name="UseStagedImport" Content="Use Staged Import (dependency-aware)"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                        <CheckBox x:Name="AutoCreateDeps" Content="Auto-create Missing Dependencies"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                        <CheckBox x:Name="DryRunMode" Content="Dry Run (no actual writes to QB 2021)"
                                  IsChecked="False" Style="{StaticResource ModernCheckBox}" />

                        <Separator Background="#2A3448" Margin="0,12,0,12" />

                        <TextBlock Text="TRANSFORMATION RULES" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#FBBF24" Margin="0,0,0,8" />
                        <CheckBox x:Name="ReactivateInactive" Content="Re-activate Inactive Entities"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                        <CheckBox x:Name="PreserveClasses" Content="Preserve Class Tracking"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                        <CheckBox x:Name="MatchAccounting" Content="Match Accounting Method"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                    </StackPanel>
                </Border>

                <!-- ── Paths Card ────────────────────────────────────── -->
                <Border Background="#1C2333" CornerRadius="8" Padding="20,16" Margin="0,0,0,16"
                        BorderBrush="#2A3448" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Output Directories" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#E8ECF1" Margin="0,0,0,16" />

                        <TextBlock Text="Export Directory" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="ExportDir" Text=".\ExportedData" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="Schema Directory" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="SchemaDir" Text=".\Schemas" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="Log Directory" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="LogDir" Text=".\Logs" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10" />

                        <TextBlock Text="Validation Report Directory" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="ValidationDir" Text=".\Validation" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,10" />

                        <Separator Background="#2A3448" Margin="0,4,0,12" />

                        <TextBlock Text="Working Directories" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#4ADE80" Margin="0,0,0,8" />

                        <TextBlock Text="Source Working Path" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="SourceWorkingDir" Text="C:\QB-TimeWarp\Working\Source"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,10" />

                        <TextBlock Text="Target Working Path" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <TextBox x:Name="TargetWorkingDir" Text="C:\QB-TimeWarp\Working\Target"
                                 Style="{StaticResource ModernTextBox}" Margin="0,0,0,10" />

                        <CheckBox x:Name="PreserveOriginals" Content="Preserve Originals (safety)"
                                  IsChecked="True" IsEnabled="False" Style="{StaticResource ModernCheckBox}" />
                    </StackPanel>
                </Border>

                <!-- ── Logging Card ──────────────────────────────────── -->
                <Border Background="#1C2333" CornerRadius="8" Padding="20,16" Margin="0,0,0,8"
                        BorderBrush="#2A3448" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Logging" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#E8ECF1" Margin="0,0,0,16" />

                        <TextBlock Text="Minimum Log Level" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                        <ComboBox x:Name="LogLevel" Style="{StaticResource ModernComboBox}"
                                  Width="200" HorizontalAlignment="Left" SelectedIndex="1"
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="Debug" />
                            <ComboBoxItem Content="Information" />
                            <ComboBoxItem Content="Warning" />
                            <ComboBoxItem Content="Error" />
                        </ComboBox>

                        <CheckBox x:Name="EnableConsoleLog" Content="Enable Console Output"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />
                        <CheckBox x:Name="EnableFileLog" Content="Enable File Output"
                                  IsChecked="True" Style="{StaticResource ModernCheckBox}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Max File Size (MB)" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="MaxLogSize" Text="100" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Retained File Count" Foreground="#6B7A90" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="RetainedFiles" Text="10" Style="{StaticResource ModernTextBox}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="3" Background="#0D1117" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save Settings" Click="SaveSettings_Click"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" />
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </Border>
    </Grid>
    </Border>
</Window>
