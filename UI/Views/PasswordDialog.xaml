<Window x:Class="QB_TimeWarp.UI.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QuickBooks Admin Password"
        Width="460" Height="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#E8ECF1"
        ResizeMode="NoResize"
        Icon="/UI/Assets/osa-icon.png">

    <Border Background="#0D1117" BorderBrush="#1A2332" BorderThickness="1" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />     <!-- Title Bar -->
                <RowDefinition Height="*" />      <!-- Content -->
                <RowDefinition Height="Auto" />   <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ═══ Custom Title Bar ═══ -->
            <Border Grid.Row="0" Background="#0D1117"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                        <Image Source="/UI/Assets/osa-icon.png" Width="16" Height="16"
                               RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0" />
                        <TextBlock Text="QuickBooks Admin Password" FontSize="12"
                                   Foreground="#6B7A90" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Content="&#xE8BB;" Click="Cancel_Click"
                            Style="{StaticResource WindowCloseButton}"
                            HorizontalAlignment="Right" />
                </Grid>
            </Border>

            <!-- ═══ Content ═══ -->
            <StackPanel Grid.Row="1" Margin="32,20,32,16" VerticalAlignment="Center">

                <!-- Icon + heading -->
                <TextBlock Text="🔐" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12" />

                <TextBlock Text="Enter the QuickBooks Admin password for the migration engine."
                           FontSize="13" Foreground="#C8D2E0" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="(Use the same password you entered in QuickBooks.)"
                           FontSize="11" Foreground="#8898B0" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="0,0,0,8" />

                <!-- File name display -->
                <TextBlock x:Name="FileNameLabel" FontSize="12" Foreground="#00D4FF"
                           TextWrapping="Wrap" TextAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,0,20" />

                <!-- Password input -->
                <Border Background="#1C2333" CornerRadius="6" Padding="4"
                        BorderBrush="#3A4660" BorderThickness="1">
                    <PasswordBox x:Name="PasswordInput"
                                 FontSize="14" Foreground="#F0F4FA"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="8,6" MaxLength="128"
                                 KeyDown="PasswordInput_KeyDown" />
                </Border>

                <TextBlock Text="Leave blank if no admin password is set."
                           FontSize="11" Foreground="#607088" Margin="4,6,0,0" />
            </StackPanel>

            <!-- ═══ Button Row ═══ -->
            <Border Grid.Row="2" Background="#0A0E14" Padding="24,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="Cancel_Click"
                            Width="90" Height="32" FontSize="13"
                            Background="#1C2333" Foreground="#C8D2E0"
                            BorderBrush="#2A3448" BorderThickness="1"
                            Cursor="Hand" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Connect" Click="OK_Click" IsDefault="True"
                            Width="110" Height="32" FontSize="13" FontWeight="SemiBold"
                            Background="#00B4D8" Foreground="#0D1117"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="12,6">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
