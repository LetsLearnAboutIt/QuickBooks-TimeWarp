<Window x:Class="QB_TimeWarp.UI.Views.EulaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Agreement — QuickBooks Time-Warp®"
        Width="700" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Foreground="#E8ECF1"
        ResizeMode="CanResizeWithGrip"
        Icon="/UI/Assets/osa-icon.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Security callout -->
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="*" />       <!-- EULA text -->
            <RowDefinition Height="Auto" />   <!-- Checkbox + links -->
            <RowDefinition Height="Auto" />   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ═══ Security Callout Banner ═══ -->
        <Border Grid.Row="0" Padding="20,16" Margin="20,20,20,0" CornerRadius="10"
                BorderThickness="1.5" BorderBrush="#00D4FF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A2540" Offset="0" />
                    <GradientStop Color="#0D3060" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#00D4FF"
                           HorizontalAlignment="Center" Margin="0,0,0,8">
                    🔒  YOUR PRIVACY GUARANTEED
                </TextBlock>
                <TextBlock TextAlignment="Center" FontSize="13" Foreground="#B0D4F1"
                           LineHeight="22">
                    Your QuickBooks file <Bold>never leaves your computer</Bold>.
                    <LineBreak />
                    We do not collect, store, or transmit any of your data.
                    <LineBreak />
                    100% local processing — zero uploads — total privacy.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="1" Padding="20,14,20,10">
            <StackPanel>
                <TextBlock Text="End User License Agreement" FontSize="18" FontWeight="Bold"
                           Foreground="#E8ECF1" />
                <TextBlock Text="Please read the following terms carefully before using QuickBooks Time-Warp®"
                           FontSize="12" Foreground="#6B7A90" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- ═══ Scrollable EULA Text ═══ -->
        <Border Grid.Row="2" Margin="20,0,20,0" Background="#151B28" CornerRadius="8"
                BorderBrush="#2A3448" BorderThickness="1" Padding="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                <TextBox x:Name="EulaTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Background="Transparent"
                         Foreground="#B0BAC9"
                         FontFamily="Segoe UI"
                         FontSize="12"
                         BorderThickness="0"
                         Padding="16,12"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled" />
            </ScrollViewer>
        </Border>

        <!-- ═══ Checkbox + Links ═══ -->
        <StackPanel Grid.Row="3" Margin="20,14,20,0">

            <!-- Agreement checkbox -->
            <CheckBox x:Name="AgreeCheckBox" Checked="AgreeCheckBox_Changed" Unchecked="AgreeCheckBox_Changed"
                      Margin="0,0,0,12">
                <TextBlock Foreground="#E8ECF1" FontSize="13" TextWrapping="Wrap">
                    <Bold>I have read and agree</Bold> to the Terms of Service and End User License Agreement
                </TextBlock>
            </CheckBox>

            <!-- Legal document links -->
            <WrapPanel Margin="24,0,0,0">
                <Button Content="📄 View Privacy Policy" Click="ViewPrivacyPolicy_Click"
                        Background="Transparent" Foreground="#00B4D8" BorderThickness="0"
                        FontSize="12" Cursor="Hand" Padding="0,2,16,2"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="#00B4D8"
                                       FontSize="12" Cursor="Hand">
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="  |  " Foreground="#2A3448" VerticalAlignment="Center" FontSize="12" />
                <Button Content="📄 View Data Security Policy" Click="ViewDataSecurity_Click"
                        Background="Transparent" Foreground="#00B4D8" BorderThickness="0"
                        FontSize="12" Cursor="Hand" Padding="0,2,16,2"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="#00B4D8"
                                       FontSize="12" Cursor="Hand">
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="  |  " Foreground="#2A3448" VerticalAlignment="Center" FontSize="12" />
                <Button Content="🔒 Security Guarantee" Click="ViewSecurityGuarantee_Click"
                        Background="Transparent" Foreground="#00B4D8" BorderThickness="0"
                        FontSize="12" Cursor="Hand" Padding="0,2,0,2"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="#00B4D8"
                                       FontSize="12" Cursor="Hand">
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </StackPanel>

        <!-- ═══ Action Buttons ═══ -->
        <Border Grid.Row="4" Background="#0A0E17" Padding="20,14" Margin="0,14,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="DeclineButton" Content="  Decline  " Click="Decline_Click"
                            Padding="24,10" Margin="0,0,12,0"
                            Background="#2A3448" Foreground="#B0BAC9" BorderThickness="1"
                            BorderBrush="#3A4A5E" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="AcceptButton" Content="  ✅  Accept &amp; Continue  " Click="Accept_Click"
                            IsEnabled="False" Padding="24,10"
                            FontSize="13" FontWeight="Bold" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#0066CC" Offset="0" />
                                                        <GradientStop Color="#0088FF" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="Bd" Property="Background"
                                                            Value="#1C2333" />
                                                    <Setter Property="Foreground" Value="#4A5568" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <TextBlock Text="v1.0.0" FontSize="11" Foreground="#4A5568"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
