<Window x:Class="QB_TimeWarp.UI.Views.CompletionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Migration Complete — QB-TimeWarp"
        Width="660" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#E8ECF1"
        ResizeMode="NoResize"
        Icon="/UI/Assets/osa-icon.png">

    <Border Background="#151B28" BorderBrush="#1A2332" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />    <!-- Title Bar -->
            <RowDefinition Height="Auto" />  <!-- Success hero -->
            <RowDefinition Height="*" />     <!-- Content -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#0D1117"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <Image Source="/UI/Assets/osa-icon.png" Width="16" Height="16"
                           RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,8,0" />
                    <TextBlock Text="Migration Complete" FontSize="12"
                               Foreground="#6B7A90" VerticalAlignment="Center" />
                </StackPanel>
                <Button Content="&#xE8BB;" Click="Close_Click"
                        Style="{StaticResource WindowCloseButton}"
                        HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ═══ Success Hero Banner ═══ -->
        <Border Grid.Row="1" Padding="28,24" Margin="24,24,24,0" CornerRadius="10"
                BorderBrush="#2A3448" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#0A1628" Offset="0" />
                    <GradientStop Color="#0D2E1A" Offset="0.5" />
                    <GradientStop Color="#112240" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="✓" FontSize="44" Foreground="#4ADE80" HorizontalAlignment="Center" />
                <TextBlock Text="Migration Complete" FontSize="24" FontWeight="Bold"
                           Foreground="#4ADE80" HorizontalAlignment="Center" Margin="0,4,0,0" />
                <TextBlock x:Name="FileNameLabel" FontSize="13" Foreground="#B0BAC9"
                           HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <!-- ═══ Content ═══ -->
        <StackPanel Grid.Row="2" Margin="24,16,24,0">

            <!-- Stats summary card -->
            <Border Background="#1C2333" CornerRadius="8" Padding="20,14" Margin="0,0,0,14"
                    BorderBrush="#2A3448" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock x:Name="ExportedLabel" FontSize="20" FontWeight="Bold"
                                   Foreground="#00D4FF" HorizontalAlignment="Center" />
                        <TextBlock Text="Exported" FontSize="10" Foreground="#6B7A90" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock x:Name="TransformedLabel" FontSize="20" FontWeight="Bold"
                                   Foreground="#FBBF24" HorizontalAlignment="Center" />
                        <TextBlock Text="Transformed" FontSize="10" Foreground="#6B7A90" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock x:Name="ImportedLabel" FontSize="20" FontWeight="Bold"
                                   Foreground="#4ADE80" HorizontalAlignment="Center" />
                        <TextBlock Text="Imported" FontSize="10" Foreground="#6B7A90" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock x:Name="FailedLabel" FontSize="20" FontWeight="Bold"
                                   Foreground="#F87171" HorizontalAlignment="Center" />
                        <TextBlock Text="Failed" FontSize="10" Foreground="#6B7A90" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Save location hint -->
            <TextBlock Grid.Row="2" x:Name="SaveLocationLabel" FontSize="12"
                       Foreground="#00B4D8" Margin="4,0,0,10" TextWrapping="Wrap" />

            <!-- Output file list -->
            <Border Background="#1C2333" CornerRadius="8" Padding="6" Margin="0,0,0,10"
                    BorderBrush="#2A3448" BorderThickness="1">
                <ListView x:Name="OutputFilesList" Background="Transparent"
                          BorderThickness="0" Foreground="#E8ECF1"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="4" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="4">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#232B3E" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="6,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="18"
                                           VerticalAlignment="Center" Margin="4,0,10,0" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}" FontSize="13" Foreground="#E8ECF1" />
                                    <TextBlock Text="{Binding SubLabel}" FontSize="10" Foreground="#6B7A90" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="Copy" Tag="{Binding FilePath}"
                                        Click="CopyToDownloads_Click" Margin="6,0"
                                        Style="{StaticResource CyanSmallButton}" />
                                <Button Grid.Column="3" Content="Open Folder" Tag="{Binding FilePath}"
                                        Click="ShowInFolder_Click"
                                        Style="{StaticResource SmallButton}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Copy All -->
            <Button Content="📋  Copy ALL to Downloads" Click="CopyAllToDownloads_Click"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource CyanWideButton}" />
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="3" Background="#0D1117" Padding="24,12">
            <Button Content="Close" Click="Close_Click"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" />
        </Border>
    </Grid>
    </Border>
</Window>
