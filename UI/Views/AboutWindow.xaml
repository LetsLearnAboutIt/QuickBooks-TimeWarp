<Window x:Class="QB_TimeWarp.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About — QuickBooks TimeWarp®"
        Width="520" Height="780"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        Foreground="#E8ECF1"
        ResizeMode="NoResize"
        Icon="/UI/Assets/osa-icon.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />      <!-- Content -->
            <RowDefinition Height="Auto" />   <!-- Footer -->
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,28,32,16">

                <!-- ═══ Logo & Product Name ═══ -->
                <Image Source="/UI/Assets/osa-logo.png"
                       Width="360" Stretch="Uniform"
                       HorizontalAlignment="Center" Margin="0,0,0,20"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- Product card -->
                <Border Background="#1C2333" CornerRadius="10" Padding="24,20"
                        BorderBrush="#2A3448" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="QuickBooks Time-Warp®" FontSize="22" FontWeight="Bold"
                                   Foreground="#E8ECF1" HorizontalAlignment="Center" />
                        <TextBlock Text="QB 2023 → QB 2021 Data Migration Tool"
                                   FontSize="13" Foreground="#6B7A90" HorizontalAlignment="Center"
                                   Margin="0,4,0,10" />
                        <Border Background="#151B28" CornerRadius="14" Padding="14,5"
                                HorizontalAlignment="Center">
                            <TextBlock Text="Version 1.0.0" FontSize="12" FontWeight="SemiBold"
                                       Foreground="#00D4FF" HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ Company Information Card ═══ -->
                <Border Background="#1C2333" CornerRadius="10" Padding="24,20"
                        BorderBrush="#2A3448" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="POWERED BY" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6B7A90" LetterSpacing="1" Margin="0,0,0,12"
                                   HorizontalAlignment="Center" />

                        <!-- OSA -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <Image Source="/UI/Assets/osa-icon.png" Width="36" Height="36"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Our System Administrator" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8ECF1" />
                                <TextBlock FontSize="12" Foreground="#00B4D8" Cursor="Hand"
                                           MouseLeftButtonUp="OpenOSAWebsite">
                                    <TextBlock.Text>oursystemadmin.com</TextBlock.Text>
                                    <TextBlock.TextDecorations>
                                        <TextDecoration Location="Underline" />
                                    </TextBlock.TextDecorations>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="A Managed IT Solutions Provider" FontSize="11"
                                   Foreground="#6B7A90" HorizontalAlignment="Center" Margin="0,2,0,14" />

                        <Separator Background="#2A3448" Margin="20,0,20,14" />

                        <!-- LRS -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Image Source="/UI/Assets/lrs-icon.png" Width="36" Height="36"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Live Remote Support, Inc" FontSize="15" FontWeight="SemiBold"
                                           Foreground="#E8ECF1" />
                                <TextBlock FontSize="12" Foreground="#00B4D8" Cursor="Hand"
                                           MouseLeftButtonUp="OpenLRSWebsite">
                                    <TextBlock.Text>liveremotesupport.net</TextBlock.Text>
                                    <TextBlock.TextDecorations>
                                        <TextDecoration Location="Underline" />
                                    </TextBlock.TextDecorations>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Security Guarantee Callout ═══ -->
                <Border CornerRadius="10" Padding="20,16"
                        BorderBrush="#00D4FF" BorderThickness="1.5" Margin="0,0,0,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0A2540" Offset="0" />
                            <GradientStop Color="#0D3060" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="Bold" Foreground="#00D4FF"
                                   HorizontalAlignment="Center" Margin="0,0,0,8">
                            🔒  100% LOCAL PROCESSING
                        </TextBlock>
                        <TextBlock TextAlignment="Center" FontSize="12" Foreground="#B0D4F1"
                                   LineHeight="20">
                            Your data <Bold>never leaves your computer</Bold>.
                            <LineBreak />
                            Zero uploads. Zero retention. Total privacy.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ═══ Legal Documents Card ═══ -->
                <Border Background="#1C2333" CornerRadius="10" Padding="24,18"
                        BorderBrush="#2A3448" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="LEGAL" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6B7A90" HorizontalAlignment="Center"
                                   Margin="0,0,0,14" />

                        <StackPanel Margin="10,0">
                            <TextBlock FontSize="13" Foreground="#00B4D8" Cursor="Hand"
                                       Margin="0,0,0,10" MouseLeftButtonUp="OpenPrivacyPolicy">
                                <TextBlock.Text>📄  Privacy Policy</TextBlock.Text>
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#00B4D8" Cursor="Hand"
                                       Margin="0,0,0,10" MouseLeftButtonUp="OpenTermsOfService">
                                <TextBlock.Text>📄  Terms of Service / EULA</TextBlock.Text>
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#00B4D8" Cursor="Hand"
                                       Margin="0,0,0,10" MouseLeftButtonUp="OpenDataSecurityPolicy">
                                <TextBlock.Text>📄  Data Security Policy</TextBlock.Text>
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="#00B4D8" Cursor="Hand"
                                       Margin="0,0,0,0" MouseLeftButtonUp="OpenSecurityGuarantee">
                                <TextBlock.Text>🔒  Security Guarantee</TextBlock.Text>
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ Technical Support Card ═══ -->
                <Border Background="#1C2333" CornerRadius="10" Padding="24,18"
                        BorderBrush="#2A3448" BorderThickness="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="TECHNICAL SUPPORT" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#6B7A90" HorizontalAlignment="Center"
                                   Margin="0,0,0,12" />

                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="📧  Email:"
                                       FontSize="13" Foreground="#B0BAC9" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="2" FontSize="13" Foreground="#00B4D8"
                                       Cursor="Hand" MouseLeftButtonUp="OpenSupportEmail">
                                <TextBlock.Text>support@oursystemadmin.com</TextBlock.Text>
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="🌐  Web:"
                                       FontSize="13" Foreground="#B0BAC9" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="2" FontSize="13" Foreground="#00B4D8"
                                       Cursor="Hand" MouseLeftButtonUp="OpenOSAWebsite">
                                <TextBlock.Text>oursystemadmin.com</TextBlock.Text>
                                <TextBlock.TextDecorations>
                                    <TextDecoration Location="Underline" />
                                </TextBlock.TextDecorations>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Footer ═══ -->
        <Border Grid.Row="1" Background="#0A0E17" Padding="24,14">
            <DockPanel>
                <Button Content="Close" Click="Close_Click" DockPanel.Dock="Right"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" />
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock FontSize="10" Foreground="#4A5568" TextWrapping="Wrap">
                        Copyright © 2010–2026
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#4A5568" TextWrapping="Wrap">
                        QuickBooks Time-Warp® powered by Our System Administrator
                        and Live Remote Support, Inc
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
