<Window x:Class="QB_TimeWarp.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QB_TimeWarp.UI.ViewModels"
        xmlns:conv="clr-namespace:QB_TimeWarp.UI.Converters"
        Title="{Binding WindowTitle}"
        Width="1100" Height="760"
        MinWidth="900" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgMain}"
        Foreground="{StaticResource TextPrimary}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Icon="/UI/Assets/osa-icon.png">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:StringToColorBrushConverter x:Key="StrToBrush" />
        <conv:CategoryToVisibilityConverter x:Key="CategoryVis" />

        <!-- Shared DataGrid column header style (DRY) -->
        <Style x:Key="DGColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#151B28" />
            <Setter Property="Foreground" Value="{StaticResource TextDim}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#2A3448" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="DGCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBody}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT SIDEBAR ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource BgDeep}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand — OSA Logo -->
                <StackPanel Grid.Row="0" Margin="14,20,14,20">
                    <Image Source="/UI/Assets/osa-icon.png"
                           Width="52" Height="52" Stretch="Uniform"
                           HorizontalAlignment="Center" Margin="0,0,0,10"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="TimeWarp" FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" />
                    <TextBlock Text="QuickBooks® Migration" FontSize="10"
                               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center"
                               Margin="0,-1,0,0" />
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavHome" Content="🏠   Home"
                            Style="{StaticResource NavButtonActive}" Click="NavHome_Click" />
                    <Button x:Name="NavMigration" Content="🔄   Migration"
                            Style="{StaticResource NavButton}" Click="NavMigration_Click" />
                    <Button x:Name="NavSettings" Content="⚙   Settings"
                            Style="{StaticResource NavButton}" Click="NavSettings_Click" />
                    <Button x:Name="NavReports" Content="📊   Reports"
                            Style="{StaticResource NavButton}" Click="NavReports_Click" />
                    <Button x:Name="NavLog" Content="📋   Activity Log"
                            Style="{StaticResource NavButton}" Click="NavLog_Click" />

                    <Separator Background="#2A3448" Margin="16,16,16,8" />
                    <Button x:Name="NavAbout" Content="ℹ   About"
                            Style="{StaticResource NavButton}" Click="NavAbout_Click" />
                </StackPanel>

                <!-- Sidebar footer -->
                <StackPanel Grid.Row="2" Margin="16,0,16,14">
                    <Separator Background="#2A3448" Margin="0,0,0,10" />
                    <TextBlock Text="v1.0.0" FontSize="10" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="© 2010–2026 OSA / LRS" FontSize="9"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ MAIN CONTENT AREA ═══════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BgMain}" Padding="0">
            <Grid Margin="28,24,28,20">

                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║                   PAGE: HOME                        ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageHome" Visibility="Visible">

                    <!-- Hero Welcome Banner -->
                    <Border Background="{StaticResource HeroBannerBg}"
                            CornerRadius="10" Padding="28,24" Margin="0,0,0,16"
                            BorderBrush="#1A3A5C" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Welcome to QuickBooks TimeWarp®"
                                           FontSize="22" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Seamlessly migrate your QuickBooks 2023 data to QuickBooks 2021 with full validation and reporting."
                                           FontSize="13" Foreground="{StaticResource TextBody}"
                                           TextWrapping="Wrap" Margin="0,8,0,14" MaxWidth="480" />
                                <Button Content="🔄  Go to Migration Console" Click="NavMigration_Click"
                                        Style="{StaticResource SuccessButton}" />
                            </StackPanel>
                            <Image Grid.Column="1" Source="/UI/Assets/osa-icon.png"
                                   Width="72" Height="72" Stretch="Uniform" Opacity="0.35"
                                   VerticalAlignment="Center" Margin="20,0,8,0"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Grid>
                    </Border>

                    <!-- Safety notice -->
                    <Border Background="#0F1923" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                            BorderBrush="#1A3A5C" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛡" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Your files are safe" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Success}" />
                                <TextBlock Text="TimeWarp never modifies your original QuickBooks files. A working copy is created automatically before migration begins."
                                           FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Quick Stats Row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ExportedCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                <TextBlock Text="Exported" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TransformedCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource Warning}" HorizontalAlignment="Center" />
                                <TextBlock Text="Transformed" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ImportedCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                <TextBlock Text="Imported" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding FailedCount}" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource Danger}" HorizontalAlignment="Center" />
                                <TextBlock Text="Failed" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Progress card (visible when running) -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding ShowProgressSection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Migration Progress" Style="{StaticResource SectionTitle}" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StepPill}"
                                        Background="{Binding ExportStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="📤 Export" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource TextMuted}" FontSize="16" VerticalAlignment="Center" Margin="8,0" />
                                <Border Grid.Column="2" Style="{StaticResource StepPill}"
                                        Background="{Binding TransformStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="🔄 Transform" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="3" Text="→" Foreground="{StaticResource TextMuted}" FontSize="16" VerticalAlignment="Center" Margin="8,0" />
                                <Border Grid.Column="4" Style="{StaticResource StepPill}"
                                        Background="{Binding ImportStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="📥 Import" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="5" Text="→" Foreground="{StaticResource TextMuted}" FontSize="16" VerticalAlignment="Center" Margin="8,0" />
                                <Border Grid.Column="6" Style="{StaticResource StepPill}"
                                        Background="{Binding ValidateStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="✓ Validate" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                            <ProgressBar Value="{Binding OverallProgress}" Minimum="0" Maximum="100"
                                         Style="{StaticResource ModernProgress}" Height="8" />
                            <DockPanel Margin="0,8,0,0">
                                <TextBlock Text="{Binding CurrentPhase, StringFormat='Phase: {0}'}"
                                           Foreground="{StaticResource TextDim}" FontSize="12" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource AccentBright}"
                                           FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║              PAGE: MIGRATION CONSOLE                ║ -->
                <!-- ║         3-Section Workflow (Source → Config → Run)   ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageMigration" Visibility="Collapsed">

                    <TextBlock Text="Migration Console" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                    <TextBlock Text="Configure and execute your QuickBooks data migration in three easy steps."
                               Style="{StaticResource DimText}" Margin="0,0,0,20" />

                    <!-- ══════════════════════════════════════════════════════
                         SECTION 1: Source File Selection
                    ══════════════════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Section header -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                    <Border Background="{StaticResource AccentBright}" CornerRadius="14"
                                            Width="28" Height="28" Margin="0,0,10,0">
                                        <TextBlock Text="1" Foreground="#0D1117" FontSize="14" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Source File Selection" Style="{StaticResource SectionTitle}" Margin="0" />
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="＋ Add QBW Files" Command="{Binding AddFilesCommand}"
                                            Style="{StaticResource ToolbarButton}" />
                                    <Button Content="✕ Remove" Command="{Binding RemoveSelectedCommand}"
                                            Style="{StaticResource ToolbarButtonSecondary}" Margin="8,0,0,0" />
                                </StackPanel>
                            </DockPanel>

                            <!-- Safety notice -->
                            <Border Background="#0C1A12" CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                                    BorderBrush="#1A3D28" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛡" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Foreground="{StaticResource Success}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold">Your original file will not be modified.</Run>
                                        <Run Foreground="{StaticResource TextDim}"> A safe working copy is created in C:\QB-TimeWarp\Working\Source\ before migration begins.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Drop zone hint -->
                            <Border Background="#0F1923" BorderBrush="{StaticResource Accent}"
                                    BorderThickness="1.5" CornerRadius="8" Padding="20,14"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Text="📂" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Drag .QBW files here — or click Add QBW Files"
                                               Foreground="{StaticResource Accent}" FontSize="13"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- File List DataGrid (enhanced with more columns) -->
                            <DataGrid ItemsSource="{Binding Files}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="None"
                                      Background="Transparent" Foreground="{StaticResource TextBody}"
                                      BorderThickness="0" RowBackground="#1C2333"
                                      AlternatingRowBackground="#1F2A3C"
                                      CanUserAddRows="False" SelectionMode="Single"
                                      VerticalScrollBarVisibility="Auto" MinHeight="60" MaxHeight="220"
                                      ColumnHeaderStyle="{StaticResource DGColumnHeader}"
                                      CellStyle="{StaticResource DGCell}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ORIGINAL FILE" Binding="{Binding FilePath}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="FontSize" Value="12" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="SIZE" Binding="{Binding FileSize}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextDim}" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="MODIFIED" Binding="{Binding LastModified}" Width="145">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextDim}" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="FontSize" Value="11" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="STATUS" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="{Binding StatusColor, Converter={StaticResource StrToBrush}}"
                                                           FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════════════════════════════════════════════
                         SECTION 2: Migration Configuration  (NEW)
                    ══════════════════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Section header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Border Background="{StaticResource AccentBright}" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="2" Foreground="#0D1117" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Migration Configuration" Style="{StaticResource SectionTitle}" Margin="0" />
                            </StackPanel>

                            <!-- ── Destination ── -->
                            <TextBlock Text="DESTINATION" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                <Button Grid.Column="1" Content="📁 Browse" Command="{Binding SelectDestinationCommand}"
                                        Style="{StaticResource ToolbarButtonSecondary}" Margin="8,0,0,0" />
                            </Grid>
                            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,0,16">
                                <Run Text="Output file:" />
                                <Run Text="{Binding DestinationPreview, Mode=OneWay}" Foreground="{StaticResource TextBody}" />
                            </TextBlock>

                            <Separator Background="#2A3448" Margin="0,0,0,16" />

                            <!-- ── Date Range ── -->
                            <TextBlock Text="DATE RANGE FILTER" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="From" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker SelectedDate="{Binding DateRangeFrom}"
                                                Background="#1C2333" Foreground="{StaticResource TextPrimary}"
                                                BorderBrush="{StaticResource BorderLight}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="To" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker SelectedDate="{Binding DateRangeTo}"
                                                Background="#1C2333" Foreground="{StaticResource TextPrimary}"
                                                BorderBrush="{StaticResource BorderLight}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                    <TextBlock Text="Leave blank for all dates" Foreground="{StaticResource TextMuted}"
                                               FontSize="11" FontStyle="Italic" />
                                </StackPanel>
                            </Grid>

                            <Separator Background="#2A3448" Margin="0,0,0,16" />

                            <!-- ── Entity Types ── -->
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="ENTITY TYPES TO MIGRATE" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource Accent}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Select All" Command="{Binding SelectAllEntitiesCommand}"
                                            Style="{StaticResource SmallButton}" />
                                    <Button Content="Deselect All" Command="{Binding DeselectAllEntitiesCommand}"
                                            Style="{StaticResource SmallButton}" Margin="6,0,0,0" />
                                </StackPanel>
                            </DockPanel>

                            <!-- List types -->
                            <TextBlock Text="Reference Data" FontSize="11" Foreground="{StaticResource TextDim}"
                                       FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding EntityTypes}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}"
                                                  Foreground="{StaticResource TextBody}" FontSize="12"
                                                  Margin="0,3,18,3" Width="170"
                                                  Visibility="{Binding Category, Converter={StaticResource CategoryVis}, ConverterParameter=List}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Transaction types -->
                            <TextBlock Text="Transactions" FontSize="11" Foreground="{StaticResource TextDim}"
                                       FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding EntityTypes}" Margin="0,0,0,6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}"
                                                  Foreground="{StaticResource TextBody}" FontSize="12"
                                                  Margin="0,3,18,3" Width="195"
                                                  Visibility="{Binding Category, Converter={StaticResource CategoryVis}, ConverterParameter=Transaction}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="#2A3448" Margin="0,10,0,16" />

                            <!-- ── Validation Level ── -->
                            <TextBlock Text="VALIDATION LEVEL" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <RadioButton Content="Quick" IsChecked="{Binding ValidationQuick}"
                                             Foreground="{StaticResource TextBody}" FontSize="13" Margin="0,0,24,0"
                                             GroupName="ValidationLevel" />
                                <RadioButton Content="Standard" IsChecked="{Binding ValidationStandard}"
                                             Foreground="{StaticResource TextBody}" FontSize="13" Margin="0,0,24,0"
                                             GroupName="ValidationLevel" />
                                <RadioButton Content="Thorough" IsChecked="{Binding ValidationThorough}"
                                             Foreground="{StaticResource TextBody}" FontSize="13"
                                             GroupName="ValidationLevel" />
                            </StackPanel>

                            <Separator Background="#2A3448" Margin="0,0,0,16" />

                            <!-- ── Estimates ── -->
                            <TextBlock Text="ESTIMATES" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#151B28" CornerRadius="6" Padding="12,10" Margin="0,0,6,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SourceFileSizeText}" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Source Size" FontSize="10" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#151B28" CornerRadius="6" Padding="12,10" Margin="3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedDestSizeText}" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource Warning}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Output" FontSize="10" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="#151B28" CornerRadius="6" Padding="12,10" Margin="3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedTimeText}" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Time" FontSize="10" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Background="#151B28" CornerRadius="6" Padding="12,10" Margin="6,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedRecordCount}" FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Records" FontSize="10" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ═════════════════════════ START MIGRATION BUTTON ═════════════════════════ -->
                    <Border Background="#0F1923" CornerRadius="8" Padding="20,16" Margin="0,0,0,12"
                            BorderBrush="#1A3A5C" BorderThickness="1"
                            Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Ready to migrate?" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="A working copy of your file will be created first. Your original remains untouched."
                                           FontSize="12" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <Button Content="▶  Start Migration" Command="{Binding StartMigrationCommand}"
                                    Style="{StaticResource SuccessButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- Running controls -->
                    <Border Background="#1C0A0A" CornerRadius="8" Padding="20,14" Margin="0,0,0,12"
                            BorderBrush="#3D1A1A" BorderThickness="1"
                            Visibility="{Binding IsMigrationRunning, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Migration in progress..." FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource Danger}" />
                                <TextBlock Text="Do not close QuickBooks Desktop while migration is running."
                                           FontSize="12" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <Button Content="■  Stop" Command="{Binding StopMigrationCommand}"
                                    Style="{StaticResource DangerButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- ══════════════════════════════════════════════════════
                         SECTION 3: Migration Progress  (shows after Start)
                    ══════════════════════════════════════════════════════ -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding ShowProgressSection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <!-- Section header -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{StaticResource AccentBright}" CornerRadius="14"
                                        Width="28" Height="28" Margin="0,0,10,0">
                                    <TextBlock Text="3" Foreground="#0D1117" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Migration Progress" Style="{StaticResource SectionTitle}" Margin="0" />
                            </StackPanel>

                            <!-- Phase Step Pipeline -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StepPill}"
                                        Background="{Binding ExportStepColor, Converter={StaticResource StrToBrush}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📤" FontSize="18" HorizontalAlignment="Center" />
                                        <TextBlock Text="Export" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource TextMuted}" FontSize="18" VerticalAlignment="Center" Margin="10,0" />
                                <Border Grid.Column="2" Style="{StaticResource StepPill}"
                                        Background="{Binding TransformStepColor, Converter={StaticResource StrToBrush}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="🔄" FontSize="18" HorizontalAlignment="Center" />
                                        <TextBlock Text="Transform" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="3" Text="→" Foreground="{StaticResource TextMuted}" FontSize="18" VerticalAlignment="Center" Margin="10,0" />
                                <Border Grid.Column="4" Style="{StaticResource StepPill}"
                                        Background="{Binding ImportStepColor, Converter={StaticResource StrToBrush}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📥" FontSize="18" HorizontalAlignment="Center" />
                                        <TextBlock Text="Import" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <TextBlock Grid.Column="5" Text="→" Foreground="{StaticResource TextMuted}" FontSize="18" VerticalAlignment="Center" Margin="10,0" />
                                <Border Grid.Column="6" Style="{StaticResource StepPill}"
                                        Background="{Binding ValidateStepColor, Converter={StaticResource StrToBrush}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="✓" FontSize="18" HorizontalAlignment="Center" />
                                        <TextBlock Text="Validate" FontSize="11" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Progress bar -->
                            <ProgressBar Value="{Binding OverallProgress}" Minimum="0" Maximum="100"
                                         Style="{StaticResource ModernProgress}" Height="8" />
                            <DockPanel Margin="0,8,0,0">
                                <TextBlock Text="{Binding CurrentPhase, StringFormat='Phase: {0}'}"
                                           Foreground="{StaticResource TextDim}" FontSize="12" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource AccentBright}"
                                           FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                            </DockPanel>

                            <Separator Background="#2A3448" Margin="0,14,0,14" />

                            <!-- Live Stats -->
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ExportedCount}" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Exported" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TransformedCount}" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource Warning}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Transformed" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ImportedCount}" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Imported" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding FailedCount}" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource Danger}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Failed" Style="{StaticResource DimText}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Inline Activity Log -->
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="Activity Log" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextDim}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                <Button Content="Clear" Command="{Binding ClearLogCommand}"
                                        Style="{StaticResource SmallButton}" DockPanel.Dock="Right"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </DockPanel>
                            <Border Background="#0D1117" CornerRadius="6" Padding="0" MinHeight="180" MaxHeight="300">
                                <TextBox Text="{Binding ActivityLog, Mode=OneWay}"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Background="Transparent" Foreground="{StaticResource TextBody}"
                                         BorderThickness="0"
                                         FontFamily="Cascadia Code, Consolas, Courier New"
                                         FontSize="11" Padding="14,10"
                                         x:Name="MigrationLogBox"
                                         TextChanged="MigrationLogBox_TextChanged" />
                            </Border>

                            <!-- Reset button (after completion) -->
                            <Button Content="🔄  Start New Migration" Command="{Binding ResetMigrationCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══ PAGE: SETTINGS ══╗ -->
                <StackPanel x:Name="PageSettings" Visibility="Collapsed">
                    <TextBlock Text="Settings" Style="{StaticResource HeaderText}" Margin="0,0,0,16" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Configure connections, paths, and import options via the dedicated Settings panel."
                                       Style="{StaticResource BodyText}" Margin="0,0,0,12" />
                            <Button Content="⚙  Open Settings Panel" Command="{Binding OpenSettingsCommand}"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══ PAGE: REPORTS ══╗ -->
                <StackPanel x:Name="PageReports" Visibility="Collapsed">
                    <TextBlock Text="Reports" Style="{StaticResource HeaderText}" Margin="0,0,0,16" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Migration reports will appear here after a completed run."
                                       Style="{StaticResource BodyText}" />
                            <TextBlock Text="Reports include validation results, entity counts, and error details."
                                       Style="{StaticResource DimText}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══ PAGE: ACTIVITY LOG ══╗ -->
                <StackPanel x:Name="PageLog" Visibility="Collapsed">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Activity Log" Style="{StaticResource HeaderText}"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <Button Content="Clear Log" Command="{Binding ClearLogCommand}"
                                Style="{StaticResource SmallButton}" DockPanel.Dock="Right"
                                HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </DockPanel>
                    <Border Style="{StaticResource Card}" Padding="0" MinHeight="400">
                        <TextBox Text="{Binding ActivityLog, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBody}"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12" Padding="16,12"
                                 x:Name="ActivityLogBox"
                                 TextChanged="ActivityLogBox_TextChanged" />
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
