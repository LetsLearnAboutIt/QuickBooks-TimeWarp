<Window x:Class="QB_TimeWarp.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QB_TimeWarp.UI.ViewModels"
        xmlns:conv="clr-namespace:QB_TimeWarp.UI.Converters"
        Title="{Binding WindowTitle}"
        Width="1100" Height="760"
        MinWidth="900" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        Foreground="{StaticResource TextPrimary}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Icon="/UI/Assets/osa-icon.png">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:StringToColorBrushConverter x:Key="StrToBrush" />
        <conv:CategoryToVisibilityConverter x:Key="CategoryVis" />

        <!-- Shared DataGrid column header style (DRY) -->
        <Style x:Key="DGColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#151B28" />
            <Setter Property="Foreground" Value="{StaticResource TextDim}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#2A3448" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="DGCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextBody}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border provides the seamless edge (no visible chrome) -->
    <Border Background="{StaticResource BgMain}" BorderBrush="#1A2332" BorderThickness="1" CornerRadius="0">
    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Custom Title Bar -->
            <RowDefinition Height="32" />
            <!-- Row 1: Main Content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════ CUSTOM TITLE BAR ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App branding (left side of title bar) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <Image Source="/UI/Assets/osa-icon.png"
                           Width="22" Height="22" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="0,0,8,0" />
                    <TextBlock Text="Company File TimeWarp" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBody}" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Center area is draggable (handled by the parent Border MouseDown) -->

                <!-- Window control buttons (right side) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnMinimize" Content="&#xE921;"
                            Style="{StaticResource WindowControlButton}"
                            Click="BtnMinimize_Click" ToolTip="Minimize" />
                    <Button x:Name="BtnMaximize" Content="&#xE922;"
                            Style="{StaticResource WindowControlButton}"
                            Click="BtnMaximize_Click" ToolTip="Maximize" />
                    <Button x:Name="BtnClose" Content="&#xE8BB;"
                            Style="{StaticResource WindowCloseButton}"
                            Click="BtnClose_Click" ToolTip="Close" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ MAIN BODY (below title bar) ═══════ -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT SIDEBAR ═══════ -->
        <Border Grid.Column="0" Background="{StaticResource BgDeep}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand — OSA Logo -->
                <StackPanel Grid.Row="0" Margin="14,20,14,20">
                    <Image Source="/UI/Assets/osa-icon.png"
                           Width="68" Height="68" Stretch="Uniform"
                           HorizontalAlignment="Center" Margin="0,0,0,10"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Company File" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                    <TextBlock Text="TimeWarp" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center"
                               Margin="0,-1,0,0" />
                    <TextBlock Text="Data Migration Tool" FontSize="10"
                               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Navigation — Workflow Steps -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavHome" Content="🏠   Home"
                            Style="{StaticResource NavButtonActive}" Click="NavHome_Click" />

                    <!-- Workflow separator -->
                    <TextBlock Text="WORKFLOW" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}"
                               Margin="18,14,0,6" />
                    <Button x:Name="NavSource" Content="📂   Source"
                            Style="{StaticResource NavButton}" Click="NavSource_Click" />
                    <Button x:Name="NavDestination" Content="📍   Destination"
                            Style="{StaticResource NavButton}" Click="NavDestination_Click" />
                    <Button x:Name="NavOptions" Content="⚙   Options"
                            Style="{StaticResource NavButton}" Click="NavOptions_Click" />
                    <Button x:Name="NavMigration" Content="▶   Run Migration"
                            Style="{StaticResource NavButton}" Click="NavMigration_Click" />

                    <Separator Background="#1A2E50" Margin="16,12,16,6" />
                    <Button x:Name="NavReports" Content="📊   Reports"
                            Style="{StaticResource NavButton}" Click="NavReports_Click" />
                    <Button x:Name="NavSettings" Content="⚙   Settings"
                            Style="{StaticResource NavButton}" Click="NavSettings_Click" />
                    <Button x:Name="NavLog" Content="📋   Activity Log"
                            Style="{StaticResource NavButton}" Click="NavLog_Click" />

                    <Separator Background="#1A2E50" Margin="16,12,16,6" />
                    <Button x:Name="NavAbout" Content="ℹ   About"
                            Style="{StaticResource NavButton}" Click="NavAbout_Click" />
                </StackPanel>

                <!-- Sidebar footer -->
                <StackPanel Grid.Row="2" Margin="16,0,16,14">
                    <Separator Background="#1A2E50" Margin="0,0,0,10" />
                    <TextBlock Text="v1.0.0" FontSize="10" Foreground="{StaticResource TextMuted}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="© 2010–2026 OSA / LRS" FontSize="9"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ MAIN CONTENT AREA ═══════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource ThinScrollViewer}"
                      Background="{StaticResource BgMain}" Padding="0">
            <Grid Margin="28,24,28,20">

                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║                   PAGE: HOME                        ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageHome" Visibility="Visible">

                    <!-- Hero Welcome Banner (Intel Pro Graphics Style — vibrant blue radial glow) -->
                    <Border CornerRadius="12" Margin="0,0,0,18"
                            BorderBrush="#1A3A6C" BorderThickness="1" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.4" Color="#0050A0" Direction="0" />
                        </Border.Effect>
                        <Grid>
                            <!-- Layer 1: Linear gradient base -->
                            <Border Background="{StaticResource HeroBannerBg}" CornerRadius="12" />
                            <!-- Layer 2: Radial blue glow overlay (atmospheric light effect) -->
                            <Border Background="{StaticResource HeroRadialGlow}" CornerRadius="12" />
                            <!-- Layer 3: Content -->
                            <Grid Margin="32,28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="Welcome to" FontSize="24" FontWeight="Medium"
                                                   Foreground="#C0D0E8" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Company File TimeWarp®" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBright}">
                                            <TextBlock.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.6" Color="#00E5FF" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="Seamlessly migrate your QB 2023 data to QB 2021 with full validation and reporting."
                                               FontSize="15" Foreground="#90A8C4"
                                               TextWrapping="Wrap" Margin="0,0,0,18" MaxWidth="480" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="📂  Start — Select Source" Click="NavSource_Click"
                                                Style="{StaticResource SuccessButton}" />
                                        <!-- Intel-style status badge -->
                                        <Border Background="#0D3320" CornerRadius="10" Padding="10,4" Margin="12,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.4" Color="#22C55E" />
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="✓" FontSize="12" FontWeight="Bold" Foreground="#4ADE80"
                                                           VerticalAlignment="Center" Margin="0,0,5,0" />
                                                <TextBlock Text="System Ready" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#4ADE80" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Image Grid.Column="1" Source="/UI/Assets/osa-icon.png"
                                       Width="84" Height="84" Stretch="Uniform" Opacity="0.25"
                                       VerticalAlignment="Center" Margin="20,0,8,0"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Safety notice -->
                    <Border Background="#0A1420" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                            BorderBrush="#1A3058" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛡" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Your files are safe" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Success}" />
                                <TextBlock Text="TimeWarp never modifies your original company files. A working copy is created automatically before migration begins."
                                           FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Quick Stats Row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ExportedCount}" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                <TextBlock Text="Exported" FontSize="12" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TransformedCount}" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource Warning}" HorizontalAlignment="Center" />
                                <TextBlock Text="Transformed" FontSize="12" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding ImportedCount}" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                <TextBlock Text="Imported" FontSize="12" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="6" Style="{StaticResource StatCard}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding FailedCount}" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource Danger}" HorizontalAlignment="Center" />
                                <TextBlock Text="Failed" FontSize="12" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Progress card (visible when running) -->
                    <Border Style="{StaticResource Card}"
                            Visibility="{Binding ShowProgressSection, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Migration Progress" Style="{StaticResource SectionTitle}" />
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StepPill}"
                                        Background="{Binding ExportStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="📤 Export" FontSize="13" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource TextMuted}" FontSize="18" VerticalAlignment="Center" Margin="8,0" />
                                <Border Grid.Column="2" Style="{StaticResource StepPill}"
                                        Background="{Binding TransformStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="🔄 Transform" FontSize="13" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="3" Text="→" Foreground="{StaticResource TextMuted}" FontSize="18" VerticalAlignment="Center" Margin="8,0" />
                                <Border Grid.Column="4" Style="{StaticResource StepPill}"
                                        Background="{Binding ImportStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="📥 Import" FontSize="13" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Grid.Column="5" Text="→" Foreground="{StaticResource TextMuted}" FontSize="18" VerticalAlignment="Center" Margin="8,0" />
                                <Border Grid.Column="6" Style="{StaticResource StepPill}"
                                        Background="{Binding ValidateStepColor, Converter={StaticResource StrToBrush}}">
                                    <TextBlock Text="✓ Validate" FontSize="13" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                            <ProgressBar Value="{Binding OverallProgress}" Minimum="0" Maximum="100"
                                         Style="{StaticResource ModernProgress}" Height="10" />
                            <DockPanel Margin="0,10,0,0">
                                <TextBlock Text="{Binding CurrentPhase, StringFormat='Phase: {0}'}"
                                           Foreground="{StaticResource TextDim}" FontSize="13" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource AccentBright}"
                                           FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║              PAGE: SOURCE (Step 1)                   ║ -->
                <!-- ║       Select source company files                 ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageSource" Visibility="Collapsed">

                    <TextBlock Text="Source File Selection" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                    <TextBlock Text="Step 1 of 4 — Choose the company files (.QBW) you want to migrate."
                               Style="{StaticResource DimText}" Margin="0,0,0,20" />

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Source header with gradient -->
                            <Border Background="{StaticResource SectionHeaderGradient}" CornerRadius="8"
                                    Padding="14,10" Margin="-6,-4,-6,16">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <Border Background="{StaticResource AccentBright}" CornerRadius="16"
                                                Width="32" Height="32" Margin="0,0,12,0">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.5" Color="#00E5FF" />
                                            </Border.Effect>
                                            <TextBlock Text="1" Foreground="#061428" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Company Files (.QBW)" Style="{StaticResource SectionTitle}" Margin="0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="＋ Add QBW Files" Command="{Binding AddFilesCommand}"
                                                Style="{StaticResource ToolbarButton}" />
                                        <Button Content="✕ Remove" Command="{Binding RemoveSelectedCommand}"
                                                Style="{StaticResource ToolbarButtonSecondary}" Margin="8,0,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Safety notice -->
                            <Border Background="#0A1420" CornerRadius="6" Padding="14,10" Margin="0,0,0,12"
                                    BorderBrush="#1A3058" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🛡" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Foreground="{StaticResource Success}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap">
                                        <Run FontWeight="SemiBold">Your original file will not be modified.</Run>
                                        <Run Foreground="{StaticResource TextDim}"> A safe working copy is created in C:\QB-TimeWarp\Working\Source\ before migration begins.</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Drop zone hint -->
                            <Border Background="#0A1428" BorderBrush="{StaticResource AccentBright}"
                                    BorderThickness="1.5" CornerRadius="8" Padding="20,14"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <TextBlock Text="📂" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                                    <TextBlock Text="Drag .QBW files here — or click Add QBW Files"
                                               Foreground="{StaticResource Accent}" FontSize="13"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- File List DataGrid -->
                            <DataGrid ItemsSource="{Binding Files}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" GridLinesVisibility="None"
                                      Background="Transparent" Foreground="{StaticResource TextBody}"
                                      BorderThickness="0" RowBackground="#141E38"
                                      AlternatingRowBackground="#182640"
                                      CanUserAddRows="False" SelectionMode="Single"
                                      VerticalScrollBarVisibility="Auto" MinHeight="60" MaxHeight="300"
                                      ColumnHeaderStyle="{StaticResource DGColumnHeader}"
                                      CellStyle="{StaticResource DGCell}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ORIGINAL FILE" Binding="{Binding FilePath}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="FontSize" Value="12" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="SIZE" Binding="{Binding FileSize}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextDim}" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="MODIFIED" Binding="{Binding LastModified}" Width="145">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextDim}" />
                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                <Setter Property="FontSize" Value="11" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="STATUS" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="{Binding StatusColor, Converter={StaticResource StrToBrush}}"
                                                           FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Estimates summary card -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="SOURCE ESTIMATES" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,6,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SourceFileSizeText}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Source Size" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedRecordCount}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Records" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="6,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedTimeText}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Time" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Navigate to next step -->
                    <Border CornerRadius="8" Padding="16,14" Margin="0,0,0,0"
                            BorderBrush="#1A3A6C" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0A1428" Offset="0" />
                                <GradientStop Color="#0E1E3C" Offset="0.5" />
                                <GradientStop Color="#0A1428" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Files selected?" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Next, configure the output destination and date range."
                                           FontSize="12" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <Button Content="Next → Destination" Click="GoToDestination_Click"
                                    Style="{StaticResource PrimaryButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </StackPanel>


                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║           PAGE: DESTINATION (Step 2)                ║ -->
                <!-- ║    Output path and date range filters only          ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageDestination" Visibility="Collapsed">

                    <TextBlock Text="Destination" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                    <TextBlock Text="Step 2 of 4 — Set your output location and date range filter."
                               Style="{StaticResource DimText}" Margin="0,0,0,20" />

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Destination header -->
                            <Border Background="{StaticResource SectionHeaderGradient}" CornerRadius="8"
                                    Padding="14,10" Margin="-6,-4,-6,18">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource AccentBright}" CornerRadius="16"
                                            Width="32" Height="32" Margin="0,0,12,0">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.5" Color="#00E5FF" />
                                        </Border.Effect>
                                        <TextBlock Text="2" Foreground="#061428" FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Output Location" Style="{StaticResource SectionTitle}" Margin="0"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- ── Destination Path ── -->
                            <TextBlock Text="OUTPUT FOLDER" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding DestinationFolder, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ModernTextBox}" IsReadOnly="True" />
                                <Button Grid.Column="1" Content="📁 Browse" Command="{Binding SelectDestinationCommand}"
                                        Style="{StaticResource ToolbarButtonSecondary}" Margin="8,0,0,0" />
                            </Grid>
                            <TextBlock Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,0,20">
                                <Run Text="Output file:" />
                                <Run Text="{Binding DestinationPreview, Mode=OneWay}" Foreground="{StaticResource TextBody}" />
                            </TextBlock>

                            <Separator Background="#1A2E50" Margin="0,0,0,18" />

                            <!-- ── Date Range ── -->
                            <TextBlock Text="DATE RANGE FILTER" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="From" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker SelectedDate="{Binding DateRangeFrom}"
                                                Background="#1C2333" Foreground="{StaticResource TextPrimary}"
                                                BorderBrush="{StaticResource BorderLight}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="To" Foreground="{StaticResource TextDim}" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker SelectedDate="{Binding DateRangeTo}"
                                                Background="#1C2333" Foreground="{StaticResource TextPrimary}"
                                                BorderBrush="{StaticResource BorderLight}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                    <TextBlock Text="Leave blank for all dates" Foreground="{StaticResource TextMuted}"
                                               FontSize="11" FontStyle="Italic" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Estimates summary card -->
                    <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="ESTIMATES" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,6,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SourceFileSizeText}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Source Size" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedDestSizeText}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource Warning}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Output" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="3,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedTimeText}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Time" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource StatCard}" Margin="6,0,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding EstimatedRecordCount}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Est. Records" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Navigate to Options -->
                    <Border CornerRadius="8" Padding="16,14" Margin="0,12,0,0"
                            BorderBrush="#1A3A6C" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0A1428" Offset="0" />
                                <GradientStop Color="#0E1E3C" Offset="0.5" />
                                <GradientStop Color="#0A1428" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Destination set?" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Next, select which entity types and validation options to use."
                                           FontSize="12" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="← Source" Click="GoToSource_Click"
                                        Style="{StaticResource ToolbarButtonSecondary}" Margin="0,0,8,0"
                                        VerticalAlignment="Center" />
                                <Button Content="Next → Options" Click="GoToOptions_Click"
                                        Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>


                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║              PAGE: OPTIONS (Step 3)                  ║ -->
                <!-- ║    Entity types, validation level                    ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageOptions" Visibility="Collapsed">

                    <TextBlock Text="Migration Options" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                    <TextBlock Text="Step 3 of 4 — Select which entity types to migrate and validation level."
                               Style="{StaticResource DimText}" Margin="0,0,0,20" />

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Options header -->
                            <Border Background="{StaticResource SectionHeaderGradient}" CornerRadius="8"
                                    Padding="14,10" Margin="-6,-4,-6,18">
                                <DockPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <Border Background="{StaticResource AccentBright}" CornerRadius="16"
                                                Width="32" Height="32" Margin="0,0,12,0">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.5" Color="#00E5FF" />
                                            </Border.Effect>
                                            <TextBlock Text="3" Foreground="#061428" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="Entity Types &amp; Validation" Style="{StaticResource SectionTitle}" Margin="0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Select All" Command="{Binding SelectAllEntitiesCommand}"
                                                Style="{StaticResource SmallButton}" />
                                        <Button Content="Deselect All" Command="{Binding DeselectAllEntitiesCommand}"
                                                Style="{StaticResource SmallButton}" Margin="6,0,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- ── Entity Types ── -->
                            <TextBlock Text="ENTITY TYPES TO MIGRATE" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,10" />

                            <!-- Reference Data (List types) -->
                            <TextBlock Text="Reference Data" FontSize="11" Foreground="{StaticResource TextDim}"
                                       FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding EntityTypes}" Margin="0,0,0,14">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}"
                                                  Foreground="{StaticResource TextBody}" FontSize="12"
                                                  Margin="0,3,18,3" Width="170"
                                                  Visibility="{Binding Category, Converter={StaticResource CategoryVis}, ConverterParameter=List}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Transactions -->
                            <TextBlock Text="Transactions" FontSize="11" Foreground="{StaticResource TextDim}"
                                       FontWeight="SemiBold" Margin="0,0,0,6" />
                            <ItemsControl ItemsSource="{Binding EntityTypes}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}"
                                                  Foreground="{StaticResource TextBody}" FontSize="12"
                                                  Margin="0,3,18,3" Width="195"
                                                  Visibility="{Binding Category, Converter={StaticResource CategoryVis}, ConverterParameter=Transaction}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Background="#1A2E50" Margin="0,10,0,16" />

                            <!-- ── Validation Level ── -->
                            <TextBlock Text="VALIDATION LEVEL" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,10" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <RadioButton Content="Quick" IsChecked="{Binding ValidationQuick}"
                                             Foreground="{StaticResource TextBody}" FontSize="13" Margin="0,0,24,0"
                                             GroupName="ValidationLevel" />
                                <RadioButton Content="Standard" IsChecked="{Binding ValidationStandard}"
                                             Foreground="{StaticResource TextBody}" FontSize="13" Margin="0,0,24,0"
                                             GroupName="ValidationLevel" />
                                <RadioButton Content="Thorough" IsChecked="{Binding ValidationThorough}"
                                             Foreground="{StaticResource TextBody}" FontSize="13"
                                             GroupName="ValidationLevel" />
                            </StackPanel>

                            <Separator Background="#1A2E50" Margin="0,16,0,16" />

                            <!-- ── FIX #61: QB2021 Template Certification ── -->
                            <TextBlock Text="QB 2021 TEMPLATE SETUP" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}" Margin="0,0,0,8" />
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextDim}" Margin="0,0,0,12">
                                One-time setup: Authorize QB-TimeWarp to access the blank QB 2021 template.
                                Open the template file in QuickBooks 2021 first, then click the button below.
                            </TextBlock>
                            <Button Content="🔐  Certify QB2021 Template"
                                    Command="{Binding CertifyTemplateCommand}"
                                    ToolTip="One-time setup: Opens a connection to certify QB-TimeWarp for the blank template in QuickBooks 2021"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"
                                    Padding="18,10" FontSize="13" />
                        </StackPanel>
                    </Border>

                    <!-- Navigate to Run Migration -->
                    <Border CornerRadius="8" Padding="16,14" Margin="0,12,0,0"
                            BorderBrush="#1A3A6C" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0A1428" Offset="0" />
                                <GradientStop Color="#0E1E3C" Offset="0.5" />
                                <GradientStop Color="#0A1428" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Configuration complete?" FontSize="15" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="Proceed to the migration execution page to start the process."
                                           FontSize="12" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="← Destination" Click="GoToDestination_Click"
                                        Style="{StaticResource ToolbarButtonSecondary}" Margin="0,0,8,0"
                                        VerticalAlignment="Center" />
                                <Button Content="Next → Run Migration" Click="GoToMigration_Click"
                                        Style="{StaticResource PrimaryButton}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>


                <!-- ╔══════════════════════════════════════════════════════╗ -->
                <!-- ║          PAGE: RUN MIGRATION (Step 4)               ║ -->
                <!-- ║   Execution-only: pipeline, log, progress           ║ -->
                <!-- ╚══════════════════════════════════════════════════════╝ -->
                <StackPanel x:Name="PageMigration" Visibility="Collapsed">

                    <TextBlock Text="Run Migration" Style="{StaticResource HeaderText}" Margin="0,0,0,4" />
                    <TextBlock Text="Step 4 of 4 — Execute and monitor the migration in real time."
                               Style="{StaticResource DimText}" Margin="0,0,0,20" />

                    <!-- ═══════ 4-STAGE PIPELINE (always visible on this page) ═══════ -->
                    <Border CornerRadius="10" Padding="20,22" Margin="0,0,0,16"
                            BorderBrush="#152040" BorderThickness="1" ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#0A1225" Offset="0" />
                                <GradientStop Color="#0C1830" Offset="0.5" />
                                <GradientStop Color="#0A1225" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <!-- Blue atmospheric overlay -->
                            <Border Background="{StaticResource BlueSpotlight}" CornerRadius="10"
                                    Margin="-20,-22" IsHitTestVisible="False" />

                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Pipeline: Circles + Connectors -->
                            <Grid Grid.Row="0" Margin="12,0,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Stage 1: Export -->
                                <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                                        Background="{Binding ExportStepColor, Converter={StaticResource StrToBrush}}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        x:Name="Stage1Circle">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="Stage1Glow" ShadowDepth="0" BlurRadius="16" Opacity="0.55" Color="#00C8FF" />
                                    </Border.Effect>
                                    <TextBlock Text="📤" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="Stage1Glow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0.35" To="0.75" Duration="0:0:1.8" />
                                                    <DoubleAnimation Storyboard.TargetName="Stage1Glow"
                                                                     Storyboard.TargetProperty="BlurRadius"
                                                                     From="12" To="24" Duration="0:0:1.8" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>

                                <!-- Connector 1→2 -->
                                <Border Grid.Column="1" Height="4" VerticalAlignment="Center" CornerRadius="2"
                                        Background="{Binding TransformStepColor, Converter={StaticResource StrToBrush}}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.4" Color="#0080C0" />
                                    </Border.Effect>
                                </Border>

                                <!-- Stage 2: Transform -->
                                <Border Grid.Column="2" Width="52" Height="52" CornerRadius="26"
                                        Background="{Binding TransformStepColor, Converter={StaticResource StrToBrush}}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        x:Name="Stage2Circle">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="Stage2Glow" ShadowDepth="0" BlurRadius="16" Opacity="0.55" Color="#00C8FF" />
                                    </Border.Effect>
                                    <TextBlock Text="🔄" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="Stage2Glow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0.35" To="0.75" Duration="0:0:2.0" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>

                                <!-- Connector 2→3 -->
                                <Border Grid.Column="3" Height="4" VerticalAlignment="Center" CornerRadius="2"
                                        Background="{Binding ImportStepColor, Converter={StaticResource StrToBrush}}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.4" Color="#0080C0" />
                                    </Border.Effect>
                                </Border>

                                <!-- Stage 3: Import -->
                                <Border Grid.Column="4" Width="52" Height="52" CornerRadius="26"
                                        Background="{Binding ImportStepColor, Converter={StaticResource StrToBrush}}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        x:Name="Stage3Circle">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="Stage3Glow" ShadowDepth="0" BlurRadius="16" Opacity="0.55" Color="#00C8FF" />
                                    </Border.Effect>
                                    <TextBlock Text="📥" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="Stage3Glow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0.35" To="0.75" Duration="0:0:2.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>

                                <!-- Connector 3→4 -->
                                <Border Grid.Column="5" Height="4" VerticalAlignment="Center" CornerRadius="2"
                                        Background="{Binding ValidateStepColor, Converter={StaticResource StrToBrush}}">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="6" Opacity="0.4" Color="#0080C0" />
                                    </Border.Effect>
                                </Border>

                                <!-- Stage 4: Validate -->
                                <Border Grid.Column="6" Width="52" Height="52" CornerRadius="26"
                                        Background="{Binding ValidateStepColor, Converter={StaticResource StrToBrush}}"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        x:Name="Stage4Circle">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="Stage4Glow" ShadowDepth="0" BlurRadius="16" Opacity="0.55" Color="#00C8FF" />
                                    </Border.Effect>
                                    <TextBlock Text="✓" FontSize="24" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="Stage4Glow"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="0.35" To="0.75" Duration="0:0:2.4" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </Grid>

                            <!-- Labels Row -->
                            <Grid Grid.Row="1" Margin="12,10,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Export" Style="{StaticResource StageLabel}" />
                                <TextBlock Grid.Column="2" Text="Transform" Style="{StaticResource StageLabel}" />
                                <TextBlock Grid.Column="4" Text="Import" Style="{StaticResource StageLabel}" />
                                <TextBlock Grid.Column="6" Text="Validate" Style="{StaticResource StageLabel}" />
                            </Grid>

                            <!-- Status Badge Row -->
                            <Grid Grid.Row="2" Margin="12,6,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#0D3320" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center">
                                    <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="#4ADE80" HorizontalAlignment="Center" />
                                </Border>
                                <Border Grid.Column="2" Background="#0D3320" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center">
                                    <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="#4ADE80" HorizontalAlignment="Center" />
                                </Border>
                                <Border Grid.Column="4" Background="#0D3320" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center">
                                    <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="#4ADE80" HorizontalAlignment="Center" />
                                </Border>
                                <Border Grid.Column="6" Background="#0D3320" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center">
                                    <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="#4ADE80" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Current phase + progress bar -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="{Binding CurrentPhase, StringFormat='Phase: {0}'}"
                                           Foreground="{StaticResource TextDim}" FontSize="14" FontWeight="SemiBold"
                                           DockPanel.Dock="Left" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource AccentBright}"
                                           FontSize="15" FontWeight="Bold" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                            </DockPanel>
                            <ProgressBar Value="{Binding OverallProgress}" Minimum="0" Maximum="100"
                                         Style="{StaticResource ModernProgress}" Height="12" />

                            <!-- Live Stats Row -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ExportedCount}" FontSize="26" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBright}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Exported" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding TransformedCount}" FontSize="26" FontWeight="Bold"
                                                   Foreground="{StaticResource Warning}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Transformed" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding ImportedCount}" FontSize="26" FontWeight="Bold"
                                                   Foreground="{StaticResource Success}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Imported" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="6" Style="{StaticResource StatCard}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding FailedCount}" FontSize="26" FontWeight="Bold"
                                                   Foreground="{StaticResource Danger}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Failed" FontSize="11" Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Start / Stop controls -->
                    <Border CornerRadius="8" Padding="20,16" Margin="0,0,0,12"
                            BorderBrush="#1A3A6C" BorderThickness="1"
                            Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#0A1428" Offset="0" />
                                <GradientStop Color="#0E1E3C" Offset="0.5" />
                                <GradientStop Color="#0A1428" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Ready to migrate?" FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}" />
                                <TextBlock Text="A working copy of your file will be created first. Your original remains untouched."
                                           FontSize="13" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <Button Content="▶  Start Migration" Command="{Binding StartMigrationCommand}"
                                    Style="{StaticResource SuccessButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- Running controls -->
                    <Border Background="#1A0C14" CornerRadius="8" Padding="20,14" Margin="0,0,0,12"
                            BorderBrush="#3D1A2A" BorderThickness="1"
                            Visibility="{Binding IsMigrationRunning, Converter={StaticResource BoolToVis}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="Migration in progress..." FontSize="17" FontWeight="Bold"
                                           Foreground="{StaticResource Danger}" />
                                <TextBlock Text="Do not close QB Desktop while migration is running."
                                           FontSize="13" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <Button Content="■  Stop" Command="{Binding StopMigrationCommand}"
                                    Style="{StaticResource DangerButton}" DockPanel.Dock="Right"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <!-- ── Real-time Activity Log (large — takes most of the page) ── -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Activity Log" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextDim}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Clear" Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource SmallButton}" Margin="0,0,8,0" />
                            <Button Content="🔄 Reset Migration" Command="{Binding ResetMigrationCommand}"
                                    Style="{StaticResource SmallButton}"
                                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </DockPanel>
                    <Border Background="#0A1018" CornerRadius="8" Padding="0" MinHeight="260" MaxHeight="500"
                            BorderBrush="#152040" BorderThickness="1">
                        <TextBox Text="{Binding ActivityLog, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent" Foreground="{StaticResource TextBody}"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="11" Padding="14,10"
                                 x:Name="MigrationLogBox"
                                 TextChanged="MigrationLogBox_TextChanged" />
                    </Border>
                </StackPanel>

                <!-- ╔══ PAGE: SETTINGS ══╗ -->
                <StackPanel x:Name="PageSettings" Visibility="Collapsed">
                    <TextBlock Text="Settings" Style="{StaticResource HeaderText}" Margin="0,0,0,16" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Configure connections, paths, and import options via the dedicated Settings panel."
                                       Style="{StaticResource BodyText}" Margin="0,0,0,12" />
                            <Button Content="⚙  Open Settings Panel" Command="{Binding OpenSettingsCommand}"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══ PAGE: REPORTS ══╗ -->
                <StackPanel x:Name="PageReports" Visibility="Collapsed">
                    <TextBlock Text="Reports" Style="{StaticResource HeaderText}" Margin="0,0,0,16" />
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Migration reports will appear here after a completed run."
                                       Style="{StaticResource BodyText}" />
                            <TextBlock Text="Reports include validation results, entity counts, and error details."
                                       Style="{StaticResource DimText}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ╔══ PAGE: ACTIVITY LOG ══╗ -->
                <StackPanel x:Name="PageLog" Visibility="Collapsed">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Activity Log" Style="{StaticResource HeaderText}"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <Button Content="Clear Log" Command="{Binding ClearLogCommand}"
                                Style="{StaticResource SmallButton}" DockPanel.Dock="Right"
                                HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </DockPanel>
                    <Border Style="{StaticResource Card}" Padding="0" MinHeight="400">
                        <TextBox Text="{Binding ActivityLog, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBody}"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12" Padding="16,12"
                                 x:Name="ActivityLogBox"
                                 TextChanged="ActivityLogBox_TextChanged" />
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>
        </Grid>
    </Grid>
    </Border>
</Window>
