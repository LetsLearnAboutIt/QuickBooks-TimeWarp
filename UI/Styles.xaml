<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         QuickBooks TimeWarp® — Intel Pro Graphics Inspired Theme
         
         Color Palette:
           BgDeep:       #0D1117   (deepest background / sidebar)
           BgMain:       #151B28   (main content background)
           BgCard:       #1C2333   (card surfaces)
           BgCardHover:  #232B3E   (card hover / elevated)
           BgInput:      #1C2333   (input field backgrounds)
           Border:       #2A3448   (subtle borders)
           BorderLight:  #3A4660   (lighter borders for inputs)
           
           Accent:       #00B4D8   (primary cyan — links, active nav)
           AccentBright: #00D4FF   (bright cyan — buttons, highlights)
           AccentGlow:   #0096C7   (pressed cyan)
           
           Success:      #4ADE80   (green — success states)
           SuccessDim:   #22C55E   (green pressed)
           Warning:      #FBBF24   (amber — warnings)
           Danger:       #F87171   (red — errors)
           DangerDim:    #EF4444   (red pressed)
           
           TextPrimary:  #E8ECF1   (headings, primary text)
           TextBody:     #B0BAC9   (body text)
           TextDim:      #6B7A90   (labels, hints)
           TextMuted:    #4A5568   (disabled, very dim)
    ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Color Brushes ───────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgDeep"       Color="#0D1117" />
    <SolidColorBrush x:Key="BgMain"       Color="#151B28" />
    <SolidColorBrush x:Key="BgCard"       Color="#1C2333" />
    <SolidColorBrush x:Key="BgCardHover"  Color="#232B3E" />
    <SolidColorBrush x:Key="BgInput"      Color="#1C2333" />
    <SolidColorBrush x:Key="BorderColor"  Color="#2A3448" />
    <SolidColorBrush x:Key="BorderLight"  Color="#3A4660" />

    <SolidColorBrush x:Key="Accent"       Color="#00C8E8" />
    <SolidColorBrush x:Key="AccentBright" Color="#00E5FF" />
    <SolidColorBrush x:Key="AccentGlow"   Color="#00A5D4" />

    <SolidColorBrush x:Key="Success"      Color="#4ADE80" />
    <SolidColorBrush x:Key="Warning"      Color="#FBBF24" />
    <SolidColorBrush x:Key="Danger"       Color="#F87171" />

    <SolidColorBrush x:Key="TextPrimary"  Color="#E8ECF1" />
    <SolidColorBrush x:Key="TextBody"     Color="#B0BAC9" />
    <SolidColorBrush x:Key="TextDim"      Color="#6B7A90" />
    <SolidColorBrush x:Key="TextMuted"    Color="#4A5568" />

    <!-- ═══ VIBRANT BLUE GRADIENT SYSTEM (Intel Pro Graphics Inspired) ═══ -->

    <!-- Hero banner: dramatic dark-to-bright blue radial (matches Intel welcome card) -->
    <LinearGradientBrush x:Key="HeroBannerBg" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#080E1A" Offset="0" />
        <GradientStop Color="#0C1A38" Offset="0.3" />
        <GradientStop Color="#122858" Offset="0.6" />
        <GradientStop Color="#1B3F7A" Offset="0.85" />
        <GradientStop Color="#2456A0" Offset="1" />
    </LinearGradientBrush>

    <!-- Hero radial overlay — bright blue glow emanating from upper-right corner -->
    <RadialGradientBrush x:Key="HeroRadialGlow" Center="0.85,0.2" RadiusX="0.8" RadiusY="1.2"
                         GradientOrigin="0.9,0.15">
        <GradientStop Color="#4000A0FF" Offset="0" />
        <GradientStop Color="#250060D0" Offset="0.4" />
        <GradientStop Color="#10003880" Offset="0.7" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>

    <!-- ── Premium Blue-Tinted Card Gradients ──────────────────────── -->
    <!-- Card gradient: blue-tinted (not gray) — matches Intel card aesthetic -->
    <LinearGradientBrush x:Key="CardGradientBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#141E38" Offset="0" />
        <GradientStop Color="#121A30" Offset="0.4" />
        <GradientStop Color="#101828" Offset="0.7" />
        <GradientStop Color="#0E1624" Offset="1" />
    </LinearGradientBrush>

    <!-- Section header: bold blue gradient with bright accent -->
    <LinearGradientBrush x:Key="SectionHeaderGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#0C1628" Offset="0" />
        <GradientStop Color="#0F1E3A" Offset="0.3" />
        <GradientStop Color="#132850" Offset="0.65" />
        <GradientStop Color="#0F1E3A" Offset="1" />
    </LinearGradientBrush>

    <!-- Stat card: blue-tinted with depth -->
    <LinearGradientBrush x:Key="StatCardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#15213C" Offset="0" />
        <GradientStop Color="#111C32" Offset="0.5" />
        <GradientStop Color="#0E1828" Offset="1" />
    </LinearGradientBrush>

    <!-- Pipeline area background: deep blue -->
    <LinearGradientBrush x:Key="PipelineBg" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#0A1225" Offset="0" />
        <GradientStop Color="#0C1830" Offset="0.5" />
        <GradientStop Color="#0A1225" Offset="1" />
    </LinearGradientBrush>

    <!-- Pipeline connector gradient (completed state) -->
    <LinearGradientBrush x:Key="PipelineConnectorActive" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#00E5FF" Offset="0" />
        <GradientStop Color="#00C8E8" Offset="1" />
    </LinearGradientBrush>

    <!-- Badge glow: intense blue radial -->
    <RadialGradientBrush x:Key="BadgeGlowBrush" Center="0.5,0.5" RadiusX="0.7" RadiusY="0.7">
        <GradientStop Color="#5000E5FF" Offset="0" />
        <GradientStop Color="#0000E5FF" Offset="1" />
    </RadialGradientBrush>

    <!-- Atmospheric blue spotlight (for overlay on important areas) -->
    <RadialGradientBrush x:Key="BlueSpotlight" Center="0.5,0.3" RadiusX="0.7" RadiusY="0.8">
        <GradientStop Color="#1800A0FF" Offset="0" />
        <GradientStop Color="#08004080" Offset="0.5" />
        <GradientStop Color="#00000000" Offset="1" />
    </RadialGradientBrush>

    <!-- Progress bar animated gradient foreground -->
    <LinearGradientBrush x:Key="ProgressBarGlow" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#00A5D4" Offset="0" />
        <GradientStop Color="#00E5FF" Offset="0.5" />
        <GradientStop Color="#33F0FF" Offset="0.75" />
        <GradientStop Color="#00E5FF" Offset="1" />
    </LinearGradientBrush>

    <!-- Status badge background (green, Intel "Up To Date" style) -->
    <SolidColorBrush x:Key="StatusBadgeGreen" Color="#22C55E" />
    <SolidColorBrush x:Key="StatusBadgePurple" Color="#7C3AED" />

    <!-- ── Text Styles ─────────────────────────────────────────────── -->
    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SubheaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
    </Style>

    <Style x:Key="DimText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextDim}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- Premium stage label (used in Norton-style pipeline) -->
    <Style x:Key="StageLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ── Card Border (blue-tinted with atmospheric blue glow) ──── -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardGradientBg}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="22,18" />
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="BorderBrush" Value="#1E2E50" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="2" BlurRadius="18" Opacity="0.35" Color="#001840" Direction="270" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Glow Card (active sections — intense blue glow halo) -->
    <Style x:Key="GlowCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="BorderBrush" Value="#3000A0FF" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0" BlurRadius="28" Opacity="0.55" Color="#0080FF" Direction="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatCardGradient}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="BorderBrush" Value="#1A2B4A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="1" BlurRadius="12" Opacity="0.25" Color="#001030" Direction="270" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Sidebar Navigation Button ───────────────────────────────── -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextDim}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="16,11" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="0" Padding="{TemplateBinding Padding}"
                            BorderThickness="3,0,0,0" BorderBrush="Transparent">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#151B28" />
                            <Setter Property="Foreground" Value="{StaticResource TextBody}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
        <Setter Property="Foreground" Value="{StaticResource AccentBright}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#151B28"
                            CornerRadius="0" Padding="{TemplateBinding Padding}"
                            BorderThickness="3,0,0,0" BorderBrush="{StaticResource AccentBright}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Primary Button (Cyan) — Enhanced ────────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBright}" />
        <Setter Property="Foreground" Value="#0D1117" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.45" Color="#00C8FF" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33EEFF" />
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="22" Opacity="0.7" Color="#00C8FF" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentGlow}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#2A3448" />
                            <Setter Property="Foreground" Value="#4A5568" />
                            <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Success Button (Green) — Enhanced ──────────────────────── -->
    <Style x:Key="SuccessButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Success}" />
        <Setter Property="Foreground" Value="#0D1117" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Padding" Value="32,13" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.3" Color="#4ADE80" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#6EE7A0" />
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.5" Color="#4ADE80" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#22C55E" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="#2A3448" />
                            <Setter Property="Foreground" Value="#4A5568" />
                            <Setter TargetName="Bd" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Danger Button (Red) ─────────────────────────────────────── -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Danger}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="24,11" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FCA5A5" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#EF4444" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Secondary / Ghost Button ────────────────────────────────── -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1C2333" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#232B3E" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#4A5568" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#2A3448" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Toolbar Button (small, outline) ─────────────────────────── -->
    <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <Style x:Key="ToolbarButtonSecondary" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <!-- ── Small Button (log clear, copy, etc.) ────────────────────── -->
    <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="CyanSmallButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="12,5" />
    </Style>

    <Style x:Key="CyanWideButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="0,13" />
    </Style>

    <!-- ── Modern ProgressBar (vibrant gradient with intense glow) ── -->
    <Style x:Key="ModernProgress" TargetType="ProgressBar">
        <Setter Property="Height" Value="10" />
        <Setter Property="Background" Value="#0C1628" />
        <Setter Property="Foreground" Value="{StaticResource ProgressBarGlow}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="5"
                                BorderBrush="#152040" BorderThickness="1" />
                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="5"
                                HorizontalAlignment="Left">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="16" Opacity="0.7" Color="#00C8FF" />
                            </Border.Effect>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Modern Styled ComboBox (Intel-inspired dropdown) ────────── -->
    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#1C2333" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ── TextBox styling ─────────────────────────────────────────── -->
    <Style x:Key="ModernTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="#1C2333" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBright}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
    </Style>

    <!-- ── CheckBox styling ────────────────────────────────────────── -->
    <Style x:Key="ModernCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBody}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- ── Step Indicator Pill (Export / Transform / Import / Validate) ── -->
    <Style x:Key="StepPill" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.35" Color="#0060A0" Direction="0" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         Custom Window Chrome — Borderless / Intel Pro Graphics Style
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Window Control Button (Minimize / Maximize) -->
    <Style x:Key="WindowControlButton" TargetType="Button">
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextDim}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1C2333" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBright}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#232B3E" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBright}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close Button (Red hover) -->
    <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#B22A1B" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         Thin Scrollbar — Dark themed, cyan accent on hover (6px)
    ═══════════════════════════════════════════════════════════════ -->

    <!-- Vertical Scrollbar Thumb -->
    <Style x:Key="ThinScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder" Background="#2A3448" CornerRadius="3"
                            Margin="1,0" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#00B4D8" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#00D4FF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical Scrollbar -->
    <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="6" />
        <Setter Property="MinWidth" Value="6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Opacity="0" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinScrollBarThumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Opacity="0" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="6" />
                <Setter Property="MinHeight" Value="6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                      Opacity="0" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinScrollBarThumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                                      Opacity="0" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ScrollViewer with thin scrollbars applied globally -->
    <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}" />
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0"
                                   Style="{StaticResource ThinScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1"
                                   Orientation="Horizontal"
                                   Style="{StaticResource ThinScrollBar}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
